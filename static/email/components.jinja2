{% macro footer() -%}
{% if not __plain__ %}
<tr>
  <td
    align="center"
    style="padding:30px 20px 20px 20px; border-top:1px solid #eeeeee;"
  >
    <img
      src="https://static.ynput.io/AYON_blackG_dot.png"
      alt="AYON Logo"
      style="width:85px; margin-bottom:10px;"
    />
    <p style="margin:10px 0 0 0; font-size:12px; color:#777;">
      {{ caller() }}
    </p>
  </td>
</tr>
{% else %}{{ caller() }}{% endif %}
{%- endmacro %}


{% macro call_to_action(text, url) -%}
{% if not __plain__ %}
  <tr>
    <td align="center" style="padding:20px;">
      <a
        href="{{ url }}"
        clicktracking="off"
        style="
          background-color:#16d4a7;
          color:#000000;
          font-weight:bold;
          font-size:14px;
          text-decoration:none;
          padding:12px 24px;
          border-radius:4px;
          display:inline-block;
        "
        >{{ text }}</a>
    </td>
  </tr>
{% else %}
  {{ text }}: {{ url }}
{% endif %}
{%- endmacro %}



{% macro paragraph() -%}{% if not __plain__ %}
<p style="margin:5px 0 0 0; font-size:14px;">
  {{ caller() }}
</p>
{% else %}
{{ caller() }}
{% endif %}{% endmacro %}
